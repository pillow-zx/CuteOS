%rename cpp_options old_cpp_options

*cpp_options:
-nostdinc -isystem @MUSL_SYSROOT@/include -isystem include%s %(old_cpp_options)

*cc1:
%(cc1_cpu) -nostdinc -isystem @MUSL_SYSROOT@/include -isystem include%s

*link_libgcc:
-L@MUSL_SYSROOT@/lib -L .%s

*libgcc:


*startfile:
%{!shared: @MUSL_SYSROOT@/lib/crt1.o} @MUSL_SYSROOT@/lib/crti.o

*endfile:
@MUSL_SYSROOT@/lib/crtn.o

*link:
-dynamic-linker @MUSL_SYSROOT@/lib/ld-musl-riscv64-sf.so.1 -nostdlib %{shared:-shared} %{static:-static} %{rdynamic:-export-dynamic}

*esp_link:


*esp_options:


*esp_cpp_options:

